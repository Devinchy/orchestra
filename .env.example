# Copia a .env (gitignored). Las API keys las consume el PROXY litellm, no orchestra.
# orchestra solo habla con el proxy en localhost — nunca ve estas keys directamente.

# --- Frontier (con tool-use de primera) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=          # Gemini

# --- Otros proveedores de programación ---
DEEPSEEK_API_KEY=
# Qwen corre local vía Ollama — no necesita key. Asegúrate de tener Ollama
# escuchando en OLLAMA_HOST (default http://localhost:11434).
OLLAMA_HOST=http://localhost:11434

# --- Proxy litellm ---
# Puerto donde levanta el proxy local. orchestra apunta aquí.
LITELLM_PROXY_URL=http://localhost:4000
# Master key del proxy (cualquier string; protege el endpoint local).
LITELLM_MASTER_KEY=sk-local-orchestra
